{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "astro/client"],
    "paths": {
      "virtual:ddys-astro/config": ["./src/runtime/types/virtual.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "tests/**/*.mjs"],
  "exclude": ["node_modules", "dist", ".astro", ".vercel", ".netlify", "coverage"]
}
