{
  "name": "ddys-astro",
  "version": "0.1.1",
  "description": "Official Astro integration for the DDYS API with injected pages, endpoints, components, content loader, caching, SEO helpers, diagnostics, and request form.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/ddys-astro",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddysiodev/ddys-astro.git"
  },
  "bugs": {
    "url": "https://github.com/ddysiodev/ddys-astro/issues"
  },
  "keywords": [
    "ddys",
    "astro",
    "astro-integration",
    "content-loader",
    "movies",
    "video",
    "api",
    "seo",
    "ssr"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./client.d.ts",
      "import": "./dist/runtime/client/index.mjs"
    },
    "./server": {
      "types": "./server.d.ts",
      "import": "./dist/runtime/server/index.mjs"
    },
    "./content": {
      "types": "./content.d.ts",
      "import": "./dist/runtime/content/index.mjs"
    },
    "./types": {
      "types": "./types.d.ts",
      "import": "./dist/runtime/types/ddys.mjs"
    },
    "./components/DdysShell": {
      "types": "./components/DdysShell.d.ts",
      "import": "./dist/runtime/components/DdysShell.astro"
    },
    "./components/DdysCard": {
      "types": "./components/DdysCard.d.ts",
      "import": "./dist/runtime/components/DdysCard.astro"
    },
    "./components/DdysGrid": {
      "types": "./components/DdysGrid.d.ts",
      "import": "./dist/runtime/components/DdysGrid.astro"
    },
    "./components/DdysMovieDetail": {
      "types": "./components/DdysMovieDetail.d.ts",
      "import": "./dist/runtime/components/DdysMovieDetail.astro"
    },
    "./components/DdysSources": {
      "types": "./components/DdysSources.d.ts",
      "import": "./dist/runtime/components/DdysSources.astro"
    },
    "./components/DdysView": {
      "types": "./components/DdysView.d.ts",
      "import": "./dist/runtime/components/DdysView.astro"
    },
    "./components/DdysSearch": {
      "types": "./components/DdysSearch.d.ts",
      "import": "./dist/runtime/components/DdysSearch.astro"
    },
    "./components/DdysRequestForm": {
      "types": "./components/DdysRequestForm.d.ts",
      "import": "./dist/runtime/components/DdysRequestForm.astro"
    },
    "./components/DdysDiagnostics": {
      "types": "./components/DdysDiagnostics.d.ts",
      "import": "./dist/runtime/components/DdysDiagnostics.astro"
    },
    "./components/*": {
      "types": "./components/*.d.ts",
      "import": "./dist/runtime/components/*.astro"
    },
    "./styles.css": "./dist/runtime/styles/ddys.css"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "index.d.ts",
    "client.d.ts",
    "server.d.ts",
    "content.d.ts",
    "types.d.ts",
    "src",
    "components",
    "examples",
    "public",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    ".env.example",
    "astro.config.example.mjs"
  ],
  "sideEffects": [
    "./dist/runtime/styles/ddys.css",
    "./src/runtime/styles/ddys.css",
    "./dist/runtime/components/*.astro",
    "./src/runtime/components/*.astro"
  ],
  "peerDependencies": {
    "astro": ">=5.0.0 <8.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.10.0",
    "astro": "^7.0.0",
    "typescript": "^5.9.0"
  },
  "scripts": {
    "build": "node tools/build-dist.mjs",
    "check": "node tools/check.mjs",
    "prepack": "node tools/build-dist.mjs",
    "test": "node tools/check.mjs && node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
